# Clé secrète pour les tokens JWT
JWT_SECRET_KEY=ma-super-clef-secrete-en-production-2026

# Clé API pour l'intelligence artificielle
GROQ_API_KEY=votre_cle_api_groq

# Configuration Supabase (URL du projet + clé service_role pour le backend)
